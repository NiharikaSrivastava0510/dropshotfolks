+// Coaching request form
+const coachForm = document.getElementById('coachForm');
+if (coachForm){
+  coachForm.addEventListener('submit', (e) => {
+    e.preventDefault();
+    const f = coachForm;
+    const get = n => (f.elements[n] && f.elements[n].value || '').trim();
+
+    const type    = (f.querySelector('input[name="coachType"]:checked') || {}).value || '';
+    const name    = get('name');
+    const address = get('address');
+    const age     = get('age');
+    const level   = get('level');
+    const email   = get('email');
+    const phone   = get('phone');
+    const conds   = get('conditions');
+
+    if (!type || !name || !address || !age || !level || !email || !phone){
+      f.reportValidity();
+      return;
+    }
+
+    const lines = [
+      `Hi Dropshot Folks team,`,
+      ``,
+      `I'd like to book a coaching session. My details:`,
+      ``,
+      `Coaching type: ${type}`,
+      `Name: ${name}`,
+      `Address: ${address}`,
+      `Age: ${age}`,
+      `Email: ${email}`,
+      `Contact number: ${phone}`,
+      `Current badminton level: ${level}`,
+    ];
+    if (conds){
+      lines.push(``, `Specific conditions (illness / injury / past experience):`, conds);
+    }
+    lines.push(``, `Thanks!`, name);
+
+    const subject = encodeURIComponent(`Coaching request — ${name} (${type})`);
+    const body    = encodeURIComponent(lines.join('\n'));
+    // EDIT-ME: change to your real address (data-edit="email")
+    const to = 'info@dropshotfolks.co.uk';
+
+    window.location.href = `mailto:${to}?subject=${subject}&body=${body}`;
+
+    const ok = document.getElementById('coachSuccess');
+    if (ok) ok.classList.add('show');
+    setTimeout(() => { f.reset(); }, 400);
+  });
+}
