+// Coaching modal open/close
+(function(){
+  const modal = document.getElementById('coachModal');
+  if (!modal) return;
+  const dialog  = modal.querySelector('.coach-modal-dialog');
+  const closeBtn = document.getElementById('coachModalClose');
+  const success = document.getElementById('coachSuccess');
+  let lastFocus = null;
+
+  function openModal(type){
+    lastFocus = document.activeElement;
+    if (coachForm){
+      coachForm.reset();
+      if (success) success.classList.remove('show');
+      if (type){
+        const radio = coachForm.querySelector(`input[name="coachType"][value="${type}"]`);
+        if (radio) radio.checked = true;
+      }
+    }
+    modal.classList.add('show');
+    modal.setAttribute('aria-hidden', 'false');
+    document.body.style.overflow = 'hidden';
+    const firstField = document.getElementById('coach-name');
+    if (firstField) setTimeout(() => firstField.focus(), 50);
+  }
+  function closeModal(){
+    modal.classList.remove('show');
+    modal.setAttribute('aria-hidden', 'true');
+    document.body.style.overflow = '';
+    if (lastFocus && lastFocus.focus) lastFocus.focus();
+  }
+
+  document.querySelectorAll('.coach-trigger').forEach(btn => {
+    btn.addEventListener('click', () => openModal(btn.getAttribute('data-coach')));
+  });
+  closeBtn.addEventListener('click', closeModal);
+  modal.addEventListener('click', (e) => { if (!dialog.contains(e.target)) closeModal(); });
+  document.addEventListener('keydown', (e) => {
+    if (e.key === 'Escape' && modal.classList.contains('show')) closeModal();
+  });
+})();
+
