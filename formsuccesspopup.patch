From 4769bbd421a17c41fd8bbe373747b4cd5dc4457c Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Tue, 9 Jun 2026 19:36:46 +0000
Subject: [PATCH] Show form success in an overlay popup and close the modal on
 dismiss

- New centered success popup (#formSuccessPopup) rendered above the
  coaching/volunteer modal with a higher z-index
- Popup carries a check icon, title, body, and an OK button
- src.js now shows the popup on success/error instead of mutating the
  inline banner inside the form
- Clicking OK, the backdrop, or pressing Escape closes the popup AND
  closes the parent modal (volunteer or coaching) and unlocks scroll
- Error state reuses the same popup with a red icon and styled heading

https://claude.ai/code/session_01CQhaur5bgTcTG5y3ok9zon
---
 index.html |  61 +++++++++++++++++++++++++++++++
 src.js     | 104 +++++++++++++++++++++++++++++++++++++----------------
 2 files changed, 134 insertions(+), 31 deletions(-)

diff --git a/index.html b/index.html
index 181f696..338f291 100644
--- a/index.html
+++ b/index.html
@@ -1248,6 +1248,55 @@ section{
 .coach-modal-close:hover{background:var(--maroon);color:var(--cream);border-color:var(--maroon)}
 @media (max-width:520px){.coach-modal-close{top:6px;right:6px}}
 
+/* form success popup — sits above the form modal */
+.form-popup{
+  position:fixed;inset:0;
+  background:rgba(28,10,13,.75);
+  z-index:400;
+  display:none;
+  align-items:center;justify-content:center;
+  padding:1.2rem;
+}
+.form-popup.show{display:flex;animation:popupFade .25s ease}
+@keyframes popupFade{from{opacity:0}to{opacity:1}}
+.form-popup-dialog{
+  background:var(--cream);
+  border-radius:12px;
+  padding:clamp(1.8rem,4vw,2.6rem);
+  max-width:460px;width:100%;
+  text-align:center;
+  box-shadow:0 30px 60px -20px rgba(0,0,0,.6);
+  animation:popupIn .35s cubic-bezier(.2,.6,.2,1);
+}
+@keyframes popupIn{from{opacity:0;transform:translateY(20px) scale(.96)}to{opacity:1;transform:none}}
+.form-popup-icon{
+  width:64px;height:64px;border-radius:50%;
+  background:rgba(61,107,65,.12);
+  color:#3d6b41;
+  display:flex;align-items:center;justify-content:center;
+  margin:0 auto 1.2rem;
+}
+.form-popup-icon svg{width:30px;height:30px}
+.form-popup-dialog h3{
+  font-family:'Fraunces',serif;font-weight:400;
+  font-size:1.7rem;line-height:1.15;letter-spacing:-.02em;
+  color:var(--maroon-deep);
+  margin-bottom:.8rem;
+}
+.form-popup-dialog p{
+  font-size:.95rem;line-height:1.55;
+  color:#3a1d22;
+  margin-bottom:1.6rem;
+}
+.form-popup-dialog p a{color:var(--maroon);text-decoration:underline}
+.form-popup-ok{
+  max-width:200px;margin:0 auto;
+}
+.form-popup.is-error .form-popup-icon{
+  background:rgba(155,28,28,.1);color:#9b1c1c;
+}
+.form-popup.is-error .form-popup-dialog h3{color:#7a1414}
+
