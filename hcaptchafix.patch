+<meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://js.hcaptcha.com https://*.hcaptcha.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://*.hcaptcha.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://api.web3forms.com https://*.hcaptcha.com https://hcaptcha.com; form-action 'self' https://api.web3forms.com; frame-src https://*.hcaptcha.com https://hcaptcha.com; child-src https://*.hcaptcha.com https://hcaptcha.com; object-src 'none'; base-uri 'self'; upgrade-insecure-requests">
