Subject: [PATCH] Add Our Team section with founder profile

- New "Our Team" nav link and #team section
- Team card layout with photo, name, role, bio, fun fact
- Founder profile for Anamika Srivastava (photo path: images/anamika.jpg)

https://claude.ai/code/session_01CQhaur5bgTcTG5y3ok9zon
---
 dropshotfolks.html | 78 ++++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 78 insertions(+)

diff --git a/dropshotfolks.html b/dropshotfolks.html
index 95a538f..3fd1ecc 100644
--- a/dropshotfolks.html
+++ b/dropshotfolks.html
@@ -594,6 +594,61 @@ section{
   .foundation-grid{grid-template-columns:1fr}
 }
 
+/* ---------- Our Team ---------- */
+.team-grid{
+  display:grid;
+  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
+  gap:2rem;
+  margin-top:2rem;
+}
+.team-card{
+  background:var(--cream);
+  border:1px solid var(--rule);
+  border-radius:8px;
+  overflow:hidden;
+  transition:transform .35s ease, box-shadow .35s ease;
+  display:flex;flex-direction:column;
+}
+.team-card:hover{
+  transform:translateY(-6px);
+  box-shadow:0 24px 55px -22px rgba(90,22,32,.35);
+}
+.team-photo{
+  width:100%;
+  aspect-ratio:3/4;
+  object-fit:cover;
+  display:block;
+}
+.team-body{
+  padding:1.6rem 1.5rem 1.8rem;
+}
+.team-name{
+  font-family:'Fraunces',serif;font-weight:400;
+  font-size:1.6rem;line-height:1.1;letter-spacing:-.02em;
+  color:var(--maroon-deep);
+  margin-bottom:.3rem;
+}
+.team-role{
+  font-family:'Geist Mono',monospace;
+  font-size:.7rem;letter-spacing:.22em;text-transform:uppercase;
+  color:var(--maroon);
+  margin-bottom:1rem;
+}
+.team-bio{
+  font-size:.95rem;line-height:1.65;
+  color:#3a1d22;
+  margin-bottom:1rem;
+}
+.team-fun{
+  font-family:'Geist Mono',monospace;
+  font-size:.78rem;
+  color:var(--beige-deep);
+  border-top:1px solid var(--rule);
+  padding-top:.9rem;
+  margin-top:.5rem;
+}
+.team-fun b{color:var(--maroon)}
+
 /* ---------- Gallery ---------- */
 .gallery-section{
   background:var(--beige-warm);
@@ -1182,6 +1237,7 @@ footer ul a:hover{color:var(--maroon)}
     </a>
     <ul>
       <li><a href="#about">About</a></li>
+      <li><a href="#team">Our Team</a></li>
       <li><a href="#photos">Photos</a></li>
       <li><a href="#games">Games</a></li>
       <li><a href="#volunteer">Volunteer</a></li>
@@ -1361,6 +1417,28 @@ footer ul a:hover{color:var(--maroon)}
   </div> -->
 </section>
 
+<!-- ============================================== OUR TEAM -->
+<section id="team">
+  <div class="section-head reveal">
+    <div class="section-label">Our Team</div>
+    <h2 class="section-title">The <em>folks</em> behind Dropshot Folks.</h2>
+  </div>
+
+  <div class="team-grid reveal">
+    <div class="team-card">
+      <img class="team-photo" src="images/anamika.jpg" alt="Anamika Srivastava — Founder of Dropshot Folks">
+      <div class="team-body">
+        <div class="team-name">Anamika Srivastava</div>
+        <div class="team-role">Founder</div>
+        <p class="team-bio">
+          By profession she's an actress and model, but by passion she loves sports — that's the reason she started Dropshot Folks. She believes in fairness, women empowerment, and is a bit crazy because she is loud, fun and a bit dramatic. One thing about her — you will enjoy with her.
+        </p>
+        <div class="team-fun"><b>Fun fact:</b> she speaks Korean.</div>
+      </div>
+    </div>
+  </div>
+</section>
+
 <!-- ============================================== PHOTOS & VIDEO -->
 <div class="gallery-section" id="photos">
   <div class="gallery-inner">
-- 
