+// Volunteer modal open/close
+(function(){
+  const modal = document.getElementById('volModal');
+  if (!modal) return;
+  const dialog   = modal.querySelector('.coach-modal-dialog');
+  const closeBtn = document.getElementById('volModalClose');
+  const form     = document.getElementById('volunteerForm');
+  const success  = document.getElementById('volSuccess');
+  let lastFocus = null;
+
+  function openModal(role){
+    lastFocus = document.activeElement;
+    if (form){
+      form.reset();
+      if (success) success.classList.remove('show');
+      const drop = document.getElementById('vol-cv-drop');
+      const note = document.getElementById('vol-cv-name');
+      if (drop) drop.classList.remove('has-file');
+      if (note){ note.textContent = ''; note.classList.remove('error'); }
+      if (role){
+        const cb = form.querySelector(`input[name="roles"][value="${role}"]`);
+        if (cb) cb.checked = true;
+      }
+    }
+    modal.classList.add('show');
+    modal.setAttribute('aria-hidden', 'false');
+    document.body.style.overflow = 'hidden';
+    const firstField = document.getElementById('vol-first');
+    if (firstField) setTimeout(() => firstField.focus(), 50);
+  }
+  function closeModal(){
+    modal.classList.remove('show');
+    modal.setAttribute('aria-hidden', 'true');
+    document.body.style.overflow = '';
+    if (lastFocus && lastFocus.focus) lastFocus.focus();
+  }
+
+  document.querySelectorAll('.vol-role').forEach(li => {
+    li.setAttribute('tabindex', '0');
+    li.setAttribute('role', 'button');
+    li.addEventListener('click', () => openModal(li.getAttribute('data-role')));
+    li.addEventListener('keydown', (e) => {
+      if (e.key === 'Enter' || e.key === ' '){ e.preventDefault(); openModal(li.getAttribute('data-role')); }
+    });
+  });
+  const openBtn = document.getElementById('volOpen');
+  if (openBtn) openBtn.addEventListener('click', () => openModal());
+  closeBtn.addEventListener('click', closeModal);
+  modal.addEventListener('click', (e) => { if (!dialog.contains(e.target)) closeModal(); });
+  document.addEventListener('keydown', (e) => {
+    if (e.key === 'Escape' && modal.classList.contains('show')) closeModal();
+  });
+})();
+
